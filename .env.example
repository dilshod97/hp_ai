# Ollama (sizning serverda ishlamoqda)
# Docker ichidan host.docker.internal orqali murojaat qilinadi
OLLAMA_BASE_URL=http://172.16.30.225:11435
LLM_MODEL=gpt-oss:20b
EMBEDDING_MODEL=bge-m3

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_LAWS=laws
QDRANT_COLLECTION_REPORTS=audit_reports
QDRANT_COLLECTION_UPLOADS=uploads

# Redis (semantic cache)
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=86400
CACHE_SIMILARITY_THRESHOLD=0.95

# RAG sozlamalari
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K=4

# LLM sozlamalari
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2500

# Yuklamalar
DATA_DIR=/data
UPLOAD_DIR=/data/uploads
LAWS_DIR=/data/laws
REPORTS_DIR=/data/reports
